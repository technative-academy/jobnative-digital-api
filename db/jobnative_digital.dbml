Project jobnative_digital {
  database_type: "PostgreSQL"
  Note: "JobNative Digital core schema for dbdiagram.io"
}

Enum company_status {
  pending
  approved
  rejected
}

Table users {
  id serial [pk]
  name varchar(200) [not null]
  email varchar(320) [unique]

  Indexes {
    (email) [unique]
  }
}

Table companies {
  id serial [pk]
  name varchar(255) [not null]
  website varchar(2048) [not null, unique]
  linkedin varchar(2048) [unique]
  industry varchar(120)
  location varchar(120)
  description text
  status company_status [not null, default: "pending"]
  created_by_user_id int
  created_at timestamptz [not null, default: `now()`]
  approved_by_user_id int
  approved_at timestamptz

  Indexes {
    (status)
    (name)
    (location)
    (website) [unique]
  }
}

Table comments {
  id serial [pk]
  company_id int [not null]
  user_id int [not null]
  body text [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (company_id)
    (user_id)
    (created_at)
  }
}

Table technologies {
  id serial [pk]
  name varchar(60) [not null, unique]
  slug varchar(60) [not null, unique]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (name) [unique]
    (slug) [unique]
  }
}

Table company_technologies {
  company_id int [not null]
  technology_id int [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (company_id, technology_id) [pk]
    (technology_id)
  }
}

Table job_roles {
  id serial [pk]
  name varchar(60) [not null, unique]
  slug varchar(60) [not null, unique]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (name) [unique]
    (slug) [unique]
  }
}

Table company_job_roles {
  company_id int [not null]
  job_role_id int [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (company_id, job_role_id) [pk]
    (job_role_id)
  }
}

Ref: companies.created_by_user_id > users.id [delete: set null]
Ref: companies.approved_by_user_id > users.id [delete: set null]

Ref: comments.company_id > companies.id [delete: cascade]
Ref: comments.user_id > users.id [delete: cascade]

Ref: company_technologies.company_id > companies.id [delete: cascade]
Ref: company_technologies.technology_id > technologies.id [delete: cascade]

Ref: company_job_roles.company_id > companies.id [delete: cascade]
Ref: company_job_roles.job_role_id > job_roles.id [delete: cascade]
