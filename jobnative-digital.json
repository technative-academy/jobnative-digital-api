    "/api/companies": {
      "get": {
        "tags": ["Companies"],
        "summary": "List approved companies",
        "description": "Returns a list of approved companies with optional filters.",
        "operationId": "listCompanies",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search term for company name or description",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Filter by company location",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tech",
            "in": "query",
            "description": "Filter by technology name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "role",
            "in": "query",
            "description": "Filter by job role name",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of approved companies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Company"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Companies"],
        "summary": "Submit a new company",
        "description": "Submit a new company with status 'pending'. Requires authentication. Accepts arrays technologyStack[] and jobRoles[] which auto-create entries if not existing.\n",
        "operationId": "createCompany",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/api_companies_body"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Company submitted successfully with pending status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Company"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/companies/{id}": {
      "get": {
        "tags": ["Companies"],
        "summary": "Get approved company by ID",
        "description": "Returns details of an approved company by its ID.",
        "operationId": "getCompanyById",
