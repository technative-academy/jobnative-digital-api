  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "AuthTokens": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT access token",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "refreshToken": {
            "type": "string",
            "description": "JWT refresh token",
            "example": "dGhpcyBpcyBhIHJlZnJlc2ggdG9rZW4uLi4="
          }
        }
      },
      "User": {
        "type": "object",
        "description": "A user registered on the platform",
        "properties": {
          "id": { "type": "integer", "example": 123 },
          "name": { "type": "string", "example": "Jane Doe" },
          "email": { "type": "string", "format": "email", "example": "jane@example.com" },
          "role": { "type": "string", "enum": ["user", "admin"], "example": "user" },
          "createdAt": { "type": "string", "format": "date-time", "example": "2023-01-01T12:00:00Z" },
          "updatedAt": { "type": "string", "format": "date-time", "example": "2023-01-10T12:00:00Z" }
        }
      },
      "Company": {
        "type": "object",
        "description": "A company that employs software developers",
        "properties": {
          "id": { "type": "integer", "example": 456 },
          "name": { "type": "string", "example": "Acme Software Inc." },
          "website": { "type": "string", "format": "uri", "example": "https://acme.com" },
          "linkedin": { "type": "string", "format": "uri", "nullable": true, "example": "https://linkedin.com/company/acme" },
          "industry": { "type": "string", "example": "Software Development" },
          "location": { "type": "string", "example": "San Francisco, CA" },
          "description": { "type": "string", "example": "Leading software development company." },
          "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "example": "approved" },
          "createdByUserId": { "type": "integer", "example": 123 },
          "approvedByUserId": { "type": "integer", "nullable": true, "example": 1 },
          "technologyStack": { "type": "array", "items": { "type": "string" }, "example": ["React", "Node.js"] },
          "jobRoles": { "type": "array", "items": { "type": "string" }, "example": ["Frontend Developer", "Backend Developer"] },
          "createdAt": { "type": "string", "format": "date-time", "example": "2023-01-01T12:00:00Z" },
          "updatedAt": { "type": "string", "format": "date-time", "example": "2023-01-10T12:00:00Z" }
        }
      },
      "JobRole": {
        "type": "object",
        "description": "A job role",
        "properties": {
          "id": { "type": "integer", "example": 10 },
          "name": { "type": "string", "example": "Frontend Developer" },
          "slug": { "type": "string", "example": "frontend-developer" },
          "createdAt": { "type": "string", "format": "date-time", "example": "2023-01-01T12:00:00Z" },
          "updatedAt": { "type": "string", "format": "date-time", "example": "2023-01-10T12:00:00Z" }
        }
      },
      "Technology": {
        "type": "object",
        "description": "A technology used by companies",
        "properties": {
          "id": { "type": "integer", "example": 20 },
          "name": { "type": "string", "example": "React" },
          "slug": { "type": "string", "example": "react" },
          "createdAt": { "type": "string", "format": "date-time", "example": "2023-01-01T12:00:00Z" },
          "updatedAt": { "type": "string", "format": "date-time", "example": "2023-01-10T12:00:00Z" }
        }
      },
      "UserCompanyState": {
        "type": "object",
        "description": "User-specific state for a company on personal dashboard",
        "properties": {
          "userId": { "type": "integer", "example": 123 },
          "companyId": { "type": "integer", "example": 456 },
          "dashboardColumn": { "type": "string", "enum": ["todo", "contacted", "favourite"], "example": "todo" },
          "personalNotes": { "type": "string", "example": "Interested in applying next quarter." },
          "createdAt": { "type": "string", "format": "date-time", "example": "2023-01-01T12:00:00Z" },
          "updatedAt": { "type": "string", "format": "date-time", "example": "2023-01-10T12:00:00Z" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "An error occurred." }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Unauthorized - Authentication required or failed",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden - Insufficient permissions",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "BadRequest": {
        "description": "Bad request - Validation error or malformed request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Conflict": {
        "description": "Conflict - Resource already exists or unique constraint violation",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    }
  }
}
