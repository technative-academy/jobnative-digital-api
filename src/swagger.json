{
  "openapi": "3.0.0",
  "info": {
    "title": "JobNative Digital API",
    "description": "JobNative Digital is a company directory API where TechNative students can discover and track companies that employ software developers. It uses Express + TypeScript with JWT Bearer token authentication (access + refresh tokens).",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://jobnative-digital-api-production.up.railway.app",
      "description": "Production (Railway)"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getApiInfo",
        "summary": "API information",
        "description": "Returns basic information about the API.",
        "responses": {
          "200": {
            "description": "API info retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "example": "JobNative Digital API"
                    },
                    "version": {
                      "type": "string",
                      "example": "1.0.0"
                    },
                    "description": {
                      "type": "string",
                      "example": "Company directory API for TechNative students"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Health check endpoint",
        "description": "Returns status of the API service.",
        "responses": {
          "200": {
            "description": "API is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "operationId": "register",
        "summary": "Register a new user",
        "description": "Creates a new user and returns access and refresh tokens.",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Jane Doe"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "jane@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "strongPassword123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully with tokens",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokens"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "login",
        "summary": "User login",
        "description": "Authenticates user and returns access and refresh tokens.",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "jane@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "strongPassword123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful with tokens",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokens"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "operationId": "refresh",
        "summary": "Refresh access token",
        "description": "Returns a new access token using a valid refresh token.",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token refreshed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accessToken": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "logout",
        "summary": "Logout user",
        "description": "Revokes the refresh token.",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logout successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Logged out successfully"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "operationId": "me",
        "summary": "Get current user profile",
        "description": "Returns the profile of the authenticated user.",
        "tags": ["Auth"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/companies": {
      "get": {
        "operationId": "listCompanies",
        "summary": "List approved companies",
        "description": "Returns a list of approved companies with optional filters.",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search term for company name or description",
            "schema": { "type": "string" }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Filter by company location",
            "schema": { "type": "string" }
          },
          {
            "name": "tech",
            "in": "query",
            "description": "Filter by technology name",
            "schema": { "type": "string" }
          },
          {
            "name": "role",
            "in": "query",
            "description": "Filter by job role name",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of approved companies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Company"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCompany",
        "summary": "Submit a new company",
        "description": "Submit a new company with status 'pending'. Requires authentication. Accepts arrays technologyStack[] and jobRoles[] which auto-create entries if not existing.",
        "tags": ["Companies"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "website"],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Acme Software Inc."
                  },
                  "website": {
                    "type": "string",
                    "format": "uri",
                    "example": "https://acme.com"
                  },
                  "linkedin": {
                    "type": "string",
                    "format": "uri",
                    "nullable": true,
                    "example": "https://linkedin.com/company/acme"
                  },
                  "industry": {
                    "type": "string",
                    "example": "Software Development"
                  },
                  "location": {
                    "type": "string",
                    "example": "San Francisco, CA"
                  },
                  "description": {
                    "type": "string",
                    "example": "Leading software development company."
                  },
                  "technologyStack": {
                    "type": "array",
                    "items": { "type": "string" },
                    "example": ["React", "Node.js"]
                  },
                  "jobRoles": {
                    "type": "array",
                    "items": { "type": "string" },
                    "example": ["Frontend Developer", "Backend Developer"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Company submitted successfully with pending status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Company"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/companies/{id}": {
      "get": {
        "operationId": "getCompanyById",
        "summary": "Get approved company by ID",
        "description": "Returns details of an approved company by its ID.",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Company ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Company details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Company"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "operationId": "updateCompany",
        "summary": "Update company by ID",
        "description": "Admin only. Updates company details.",
        "tags": ["Companies"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Company ID",
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "website": { "type": "string", "format": "uri" },
                  "linkedin": { "type": "string", "format": "uri", "nullable": true },
                  "industry": { "type": "string" },
                  "location": { "type": "string" },
                  "description": { "type": "string" },
                  "status": {
                    "type": "string",
                    "enum": ["pending", "approved", "rejected"]
                  },
                  "technologyStack": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "jobRoles": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Company updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Company"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "delete": {
        "operationId": "deleteCompany",
        "summary": "Delete company by ID",
        "description": "Admin only. Deletes a company.",
        "tags": ["Companies"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Company ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "204": {
            "description": "Company deleted successfully"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/api/admin/companies": {
      "get": {
        "operationId": "listAllCompanies",
        "summary": "List all companies (admin)",
        "description": "Admin only. Returns all companies regardless of status, with optional status filter.",
        "tags": ["AdminCompanies"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter by approval status",
            "schema": {
              "type": "string",
              "enum": ["pending", "approved", "rejected"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of all companies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Company"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/api/admin/companies/pending": {
      "get": {
        "operationId": "listPendingCompanies",
        "summary": "List companies pending approval",
        "description": "Admin only. Returns companies with status 'pending'.",
        "tags": ["AdminCompanies"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of pending companies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Company"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/companies/{id}/approve": {
      "patch": {
        "operationId": "approveCompany",
        "summary": "Approve company by ID",
        "description": "Admin only. Approves a pending company.",
        "tags": ["AdminCompanies"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Company ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Company approved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Company"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/api/admin/companies/{id}/reject": {
      "patch": {
        "operationId": "rejectCompany",
        "summary": "Reject company by ID",
        "description": "Admin only. Rejects a pending company.",
        "tags": ["AdminCompanies"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Company ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Company rejected successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Company"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/api/job-roles": {
      "get": {
        "operationId": "listJobRoles",
