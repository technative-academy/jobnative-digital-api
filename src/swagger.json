    "/api/user-company-states": {
      "get": {
        "operationId": "listStates",
        "summary": "List user-company states",
        "description": "Returns all user-company states for the authenticated user.",
        "tags": ["UserCompanyStates"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of user-company states",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserCompanyState"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/user-company-states/{companyId}": {
      "get": {
        "operationId": "getState",
        "summary": "Get user-company state by company ID",
        "description": "Returns the user-specific state for a given company.",
        "tags": ["UserCompanyStates"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "companyId",
            "in": "path",
            "required": true,
            "description": "Company ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "User-company state found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserCompanyState"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "operationId": "upsertState",
        "summary": "Upsert user-company state by company ID",
        "description": "Creates or updates the user-company state.",
        "tags": ["UserCompanyStates"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "companyId",
            "in": "path",
            "required": true,
            "description": "Company ID",
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "dashboardColumn": {
                    "type": "string",
                    "enum": ["todo", "contacted", "favourite"],
                    "example": "todo"
                  },
                  "personalNotes": {
                    "type": "string",
                    "example": "Interested in applying next quarter."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
